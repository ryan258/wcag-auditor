# ─── OpenRouter API key (required for --user-pass) ───────────────────────────
# Sign up at https://openrouter.ai to get a key.
OPENROUTER_API_KEY=

# Optional: use a project-specific key instead of the generic one above.
# When both are set, WCAG_OPENROUTER_API_KEY takes precedence.
# WCAG_OPENROUTER_API_KEY=

# ─── Model selection ─────────────────────────────────────────────────────────
# Set a default model that all three agents will use…
WCAG_USER_PASS_DEFAULT_MODEL=google/gemini-2.5-flash-preview

# …or override per agent. Unset agents fall back to the default model.
# WCAG_USER_PASS_SCREEN_READER_MODEL=
# WCAG_USER_PASS_COGNITIVE_MODEL=
# WCAG_USER_PASS_COPYWRITER_MODEL=
# WCAG_USER_PASS_EXECUTIVE_MODEL=

# ─── Limits ──────────────────────────────────────────────────────────────────
# Maximum number of representative pages to send through the user pass.
# WCAG_USER_PASS_MAX_PAGES=8

# Timeout (seconds) for each OpenRouter API call.
# WCAG_USER_PASS_TIMEOUT_SECONDS=60

# ─── OpenRouter optional headers ─────────────────────────────────────────────
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_APP_TITLE=wcag-auditor
# OPENROUTER_HTTP_REFERER=
